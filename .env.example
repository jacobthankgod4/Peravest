# Supabase Configuration
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# API Configuration
REACT_APP_API_URL=https://api.peravest.com

# Flutterwave Configuration
# Get keys from: https://dashboard.flutterwave.com/settings/apis
REACT_APP_FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
REACT_APP_FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key

# App Configuration
REACT_APP_APP_NAME=PeraVest
REACT_APP_VERSION=1.0.0

# Environment
REACT_APP_ENV=production
